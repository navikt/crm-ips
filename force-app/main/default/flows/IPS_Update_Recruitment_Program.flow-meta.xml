        <label>Opt in RP</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Work_Trail__c</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>IPS_Is_healthcare_related__c</field>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputAssignments>
        <inputReference>$Record.Work_Trail__r</inputReference>
    </recordUpdates>
    <recordUpdates>
