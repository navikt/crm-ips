<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>IPS_Detailed_Endcause_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND (!ISBLANK(TEXT( End_Cause__c) ), ISBLANK(TEXT( Detailed_end_cause__c )))</errorConditionFormula>
    <errorDisplayField>Detailed_end_cause__c</errorDisplayField>
    <errorMessage>Husk å velge en detaljert årsak!</errorMessage>
</ValidationRule>
