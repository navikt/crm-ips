<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>IPS_Endcause_Required</fullName>
    <active>true</active>
    <errorConditionFormula>AND (!ISBLANK( End_Date__c ), ISBLANK(TEXT(End_Cause__c)))</errorConditionFormula>
    <errorDisplayField>End_Cause__c</errorDisplayField>
    <errorMessage>Sluttårsak må fylles ut når sluttdato er fylt ut!</errorMessage>
</ValidationRule>
